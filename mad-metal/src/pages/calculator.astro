---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import RatioCalculator from '../components/RatioCalculator';
import RelatedResources from '../components/RelatedResources.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout title="Coffee Ratio Calculator" description="Precision coffee-to-water ratio calculator. Works bidirectionally for any brew method.">
  <Container as="section" class="py-24">
    <div class="mb-16 max-w-[65ch]">
      <h1 class="mb-6">Ratio Calculator.</h1>
      <p class="text-xl text-body max-w-[50ch] leading-relaxed">
        Dial in your brew with mathematical precision. Adjust any value to calculate the others.
      </p>
    </div>

    <div class="bg-card border border-border rounded-2xl shadow-2xl p-8 md:p-16 w-full min-w-0">
      <RatioCalculator client:load />
    </div>

    <div class="mt-24 grid grid-cols-1 md:grid-cols-2 gap-16 min-w-0">
      <div class="min-w-0">
        <h3 class="text-xl font-bold mb-4">Why the ratio matters.</h3>
        <p class="text-sm text-body leading-relaxed max-w-[65ch]">
          The ratio of coffee to water is the most critical variable in brewing. 
          Too much coffee results in an over-concentrated, sour cup. Too little coffee leads to over-extraction and bitterness.
          Finding your "sweet spot" is the key to consistent, delicious coffee.
        </p>
      </div>
      <div class="min-w-0">
        <h3 class="text-xl font-bold mb-4">Common Ratios.</h3>
        <ul class="space-y-4">
          <li class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm font-medium">Pourover (V60, Kalita)</span>
            <span class="text-xs font-mono bg-background px-2 py-1 rounded">1:15 - 1:17</span>
          </li>
          <li class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm font-medium">Immersion (French Press)</span>
            <span class="text-xs font-mono bg-background px-2 py-1 rounded">1:12 - 1:15</span>
          </li>
          <li class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm font-medium">AeroPress</span>
            <span class="text-xs font-mono bg-background px-2 py-1 rounded">1:13 - 1:16</span>
          </li>
        </ul>
        <div class="mt-8 p-4 bg-background border border-border rounded-lg">
          <h4 class="text-sm font-bold mb-2">Need to calculate ratio from yield?</h4>
          <p class="text-xs text-body mb-3">If you already have your beverage weight, use our Yield Calculator.</p>
          <a href="/yield" class="text-sm font-medium text-link hover:underline flex items-center gap-1">
            Go to Yield Calculator <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-24">
      <FAQ 
        title="Ratio Calculation FAQs" 
        ids={['calculate-coffee-water-ratio', 'golden-ratio-coffee', 'why-ratio-important', 'weight-vs-volume-coffee', '1-16-ratio-in-ounces']} 
      />
    </div>

    <RelatedResources title="Brewing Guides & Tips" />
  </Container>
</Layout>
