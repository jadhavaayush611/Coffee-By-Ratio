---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import RatioCalculator from '../components/RatioCalculator';
import WebApplicationSchema from '../components/schemas/WebApplicationSchema.astro';
import FAQ from '../components/FAQ.astro';
import AdSlot from '../components/AdSlot.astro';
---

<Layout title="Coffee Ratio Calculator & Brewing Timer">
	<WebApplicationSchema 
		name="Coffee Ratio Calculator" 
		description="Precision coffee tools for engineers and enthusiasts. Dial in your brew by adjusting the ratio, coffee weight, or water volume instantly."
		url="https://coffeebyratio.com"
	/>
	
	<Container as="section" class="pt-16 md:pt-32 pb-16 md:pb-24">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr,600px] gap-12 lg:gap-24 items-center min-w-0">
			<div class="min-w-0">
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-link-bg-soft text-link text-xs font-medium mb-8">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-link opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-link"></span>
					</span>
					Introducing interactive brew timers
				</div>
				<h1 class="mb-6 text-balance max-w-[15ch]">
					The perfect brew starts with the right ratio.
				</h1>
				<p class="text-xl text-body mb-10 max-w-[50ch] text-balance leading-relaxed">
					Precision coffee tools for engineers and enthusiasts. 
					Dial in your brew by adjusting the ratio, coffee weight, or water volume instantly.
				</p>
				<div class="hidden lg:flex items-center gap-4">
					<a href="/guides" class="px-10 py-4 bg-primary text-on-primary font-semibold rounded-2xl hover:opacity-90 transition-opacity shadow-md">
						Explore Timers
					</a>
					<a href="/guides" class="px-10 py-4 bg-card border border-border text-foreground font-semibold rounded-2xl hover:bg-background transition-colors text-base shadow-sm">
						Browse Guides
					</a>
				</div>
			</div>

			<div class="bg-card border border-border rounded-2xl shadow-2xl p-8 md:p-12 w-full min-w-0">
				<RatioCalculator client:load />
				<div class="mt-8 pt-8 border-t border-border lg:hidden">
					<a href="/guides" class="block text-center px-8 py-4 bg-primary text-on-primary font-semibold rounded-2xl hover:opacity-90 transition-opacity shadow-md">
						Start Brewing with Timer
					</a>
				</div>
			</div>
		</div>
	</Container>

	<Container as="section" class="py-24 border-t border-border">
		<div class="w-full min-w-0">
			<FAQ limit={6} title="Common Brewing Questions" showViewAll={false} />
			<div class="mt-12 text-center">
				<a href="/faqs" class="inline-flex items-center gap-2 text-base font-semibold text-primary hover:underline">
					View all FAQ questions
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
				</a>
			</div>
		</div>
	</Container>

	<AdSlot adSlot="1234567890" className="bg-background border-y border-border w-full" />

	<Container as="section" class="py-24 border-t border-border">
		<h2 class="text-4xl md:text-5xl font-bold mb-16 text-center tracking-tight">Built for the modern brewer.</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-10 min-w-0">
			<div class="p-8 rounded-2xl bg-card border border-border shadow-lg hover:shadow-xl transition-all w-full min-w-0">
				<div class="text-link mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				</div>
				<h3 class="text-xl font-bold mb-4 text-foreground">Integrated Timers</h3>
				<p class="text-body leading-relaxed max-w-[65ch]">
					Follow your guide with real-time timers for blooming, pouring, and drawdown.
				</p>
			</div>
			<div class="p-8 rounded-2xl bg-card border border-border shadow-lg hover:shadow-xl transition-all w-full min-w-0">
				<div class="text-warning mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9a4 4 0 0 0-2 7.5"/><path d="M12 3v2"/><path d="m6.6 4.7 1.4 1.4"/><path d="M2 12h2"/><path d="m4.7 17.4 1.4-1.4"/><path d="M12 21v-2"/><path d="m17.4 19.3-1.4-1.4"/><path d="M22 12h-2"/><path d="m19.3 6.6-1.4 1.4"/><path d="M15.5 12a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"/></svg>
				</div>
				<h3 class="text-xl font-bold mb-4 text-foreground">Temperature Logic</h3>
				<p class="text-body leading-relaxed mb-6 max-w-[65ch]">
					Dial in the perfect water temperature based on your roast level and brew method.
				</p>
				<a href="/temperature" class="text-sm font-bold text-primary uppercase tracking-wider hover:underline inline-flex items-center gap-1">
					Check Temperature <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
				</a>
			</div>
			<div class="p-8 rounded-2xl bg-card border border-border shadow-lg hover:shadow-xl transition-all w-full min-w-0">
				<div class="text-cyan mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
				</div>
				<h3 class="text-xl font-bold mb-4 text-foreground">SEO Optimized</h3>
				<p class="text-body leading-relaxed max-w-[65ch]">
					Multi-page architecture ensures every brew method and tool is discoverable.
				</p>
			</div>
		</div>
	</Container>
</Layout>
