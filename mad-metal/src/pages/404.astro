---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="404: Page Not Found" description="Sorry, we couldn't find the brewing guide or tool you were looking for.">
  <Container class="py-32 text-center">
    <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 text-primary mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </div>
    <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">Grind finer.</h1>
    <p class="text-xl text-body mb-12 max-w-[50ch] mx-auto leading-relaxed">
      Sorry, we couldn't find the page you were looking for. It might have moved, or the link might be broken.
    </p>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4">
      <a href="/" class="px-8 py-4 bg-primary text-on-primary font-semibold rounded-2xl hover:opacity-90 transition-opacity w-full md:w-auto">
        Back to Home
      </a>
      <a href="/guides" class="px-8 py-4 bg-canvas border border-hairline text-ink font-semibold rounded-2xl hover:bg-canvas-soft transition-colors w-full md:w-auto">
        Explore Brewing Guides
      </a>
    </div>
  </Container>
</Layout>
