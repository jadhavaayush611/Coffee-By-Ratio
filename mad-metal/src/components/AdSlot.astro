---
interface Props {
  adClient?: string;
  adSlot: string;
  adFormat?: "auto" | "fluid" | "rectangle" | "vertical" | "horizontal";
  fullWidthResponsive?: boolean;
  className?: string;
  style?: string;
}

const {
  adClient = "ca-pub-XXXXXXXXXXXXXXXX", // Default or passed as prop
  adSlot,
  adFormat = "auto",
  fullWidthResponsive = true,
  className = "",
  style = "display:block",
} = Astro.props;

/**
 * AdSlot Component
 * 
 * Prevents Layout Shift (CLS) by reserving space for the ad.
 * AdSense approval requires clear ad placement and policy-compliant pages.
 */
---

<div class={`ad-container my-8 mx-auto w-full max-w-7xl px-4 ${className}`}>
  <div class="ad-placeholder-wrapper relative bg-muted-background border border-border rounded-md overflow-hidden min-h-[100px] sm:min-h-[250px] md:min-h-[280px]">
    <!-- Placeholder Label (Visible in dev or if ad fails to load) -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <span class="text-[10px] font-mono uppercase tracking-widest text-muted opacity-50">Advertisement</span>
    </div>

    <ins
      class="adsbygoogle"
      style={style}
      data-ad-client={adClient}
      data-ad-slot={adSlot}
      data-ad-format={adFormat}
      data-full-width-responsive={fullWidthResponsive.toString()}
    >
    </ins>
  </div>
</div>

<script is:inline>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>

<style>
  /* Ensure the ins tag fills the container */
  .adsbygoogle {
    width: 100%;
    height: 100%;
  }
  
  /* Additional styling to ensure CLS prevention */
  .ad-placeholder-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
