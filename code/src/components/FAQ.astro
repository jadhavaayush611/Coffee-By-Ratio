---
import { faqs as allFaqs, type FAQ } from "../data/faqs";
import FAQSchema from "./schemas/FAQSchema.astro";

interface Props {
  ids?: string[]; // Optional: only show specific FAQs by slug
  limit?: number; // Optional: limit the number of FAQs shown
  title?: string;
  showViewAll?: boolean;
  centered?: boolean;
}

const { ids, limit, title = "Frequently Asked Questions", showViewAll = true, centered = false } = Astro.props;


let displayFaqs = ids 
  ? allFaqs.filter(f => ids.includes(f.slug)) 
  : allFaqs;

if (limit) {
  displayFaqs = displayFaqs.slice(0, limit);
}

const faqSchemaItems = displayFaqs.map(faq => ({
  question: faq.question,
  answer: faq.answer
}));
---

<section class="w-full py-12 min-w-[280px] break-words">
  <FAQSchema faqs={faqSchemaItems} />
  <div class:list={[
    "flex flex-col gap-4 mb-8 min-w-0",
    centered ? "items-center text-center" : "md:flex-row md:items-center justify-between"
  ]}>
    <h2 class:list={[
      "text-2xl md:text-3xl font-bold text-foreground break-words",
      centered ? "max-w-2xl text-center mx-auto" : "max-w-[12ch]"
    ]}>{title}</h2>
    {(limit || ids) && showViewAll && (
      <a href="/faqs" class="text-sm font-medium text-link hover:underline inline-flex items-center gap-1 shrink-0">
        View all FAQs
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    )}
  </div>
  
  <div class="space-y-4 w-full">
    {displayFaqs.map((faq) => (
      <details class="group border border-border rounded-2xl bg-card overflow-hidden transition-all duration-300 hover:border-primary/30 w-full shadow-sm">
        <summary class="flex items-center justify-between p-6 cursor-pointer list-none focus:outline-none focus:ring-2 focus:ring-primary/20 w-full">
          <span class="text-xl font-semibold text-foreground pr-8 break-words">{faq.question}</span>
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            width="20" 
            height="20" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            class="text-muted transition-transform duration-300 group-open:rotate-180 shrink-0"
          >
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </summary>
        <div class="px-5 pb-5 text-body leading-relaxed animate-in fade-in slide-in-from-top-1 duration-300 w-full max-w-[65ch] break-words">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  @reference "../styles/global.css";

  /* Remove default arrow in some browsers */
  summary::-webkit-details-marker {
    display: none;
  }
  
  details[open] summary {
    @apply border-b border-border mb-4;
  }

  details {
    transition: all 0.3s ease-out;
  }

  details[open] {
    @apply ring-1 ring-primary/10 shadow-sm;
  }
</style>
