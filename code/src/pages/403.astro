---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="403: Forbidden" description="You don't have permission to access this recipe or brewing workbench.">
  <Container class="py-32 text-center">
    <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-warning/10 text-warning mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>
    <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight text-ink">Baristas only.</h1>
    <p class="text-xl text-body mb-12 max-w-[50ch] mx-auto leading-relaxed">
      You don't have permission to access this page. This recipe or portion of the coffee workbench is restricted.
    </p>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4">
      <a href="/" class="px-8 py-4 bg-primary text-on-primary font-semibold rounded-2xl hover:opacity-90 transition-opacity w-full md:w-auto text-center">
        Back to Home
      </a>
      <a href="/calculator" class="px-8 py-4 bg-canvas border border-hairline text-ink font-semibold rounded-2xl hover:bg-canvas-soft transition-colors w-full md:w-auto text-center">
        Ratio Calculator
      </a>
    </div>
  </Container>
</Layout>
