---
import Layout from '../../layouts/Layout.astro';
import BrewTimer from '../../components/BrewTimer';

const v60Steps = [
  {
    title: 'Bloom',
    duration: 45,
    description: 'Pour 50g of water. Gently stir to ensure all grounds are wet. Wait for CO2 to escape.',
    targetWater: 50
  },
  {
    title: 'First Pour',
    duration: 60,
    description: 'Pour water in circular motions up to 150g. Keep the stream steady.',
    targetWater: 150
  },
  {
    title: 'Second Pour',
    duration: 45,
    description: 'Pour remaining water up to 250g. Gently swirl the brewer for a flat bed.',
    targetWater: 250
  },
  {
    title: 'Drawdown',
    duration: 60,
    description: 'Let the water filter through completely. Aim for a total time of 3:00 - 3:30.',
  }
];
---

<Layout title="Hario V60 Guide" description="Step-by-step Hario V60 brewing guide with interactive timer and precision ratios.">
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-24">
    <div class="flex flex-col md:flex-row gap-12 items-start mb-16">
      <div class="flex-grow">
        <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-muted mb-6">
          <a href="/guides" class="hover:text-foreground">Guides</a>
          <span>/</span>
          <span class="text-foreground">Hario V60</span>
        </nav>
        <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">Hario V60.</h1>
        <p class="text-lg text-body mb-8 leading-relaxed">
          The Hario V60 is a classic pour-over brewer that rewards precision. 
          Its 60° angle and large exit hole allow for a faster flow, giving you maximum control over extraction and flavor clarity.
        </p>
        <div class="grid grid-cols-3 gap-8 p-6 bg-card border border-border rounded-xl">
          <div>
            <span class="text-[10px] font-mono uppercase tracking-widest text-muted block mb-1">Ratio</span>
            <span class="text-lg font-bold">1:16</span>
          </div>
          <div>
            <span class="text-[10px] font-mono uppercase tracking-widest text-muted block mb-1">Grind</span>
            <span class="text-lg font-bold">Medium-Fine</span>
          </div>
          <div>
            <span class="text-[10px] font-mono uppercase tracking-widest text-muted block mb-1">Temp</span>
            <span class="text-lg font-bold">94°C</span>
          </div>
        </div>
      </div>
      <div class="w-full md:w-1/3 aspect-square bg-cyan/10 rounded-2xl flex items-center justify-center text-cyan border border-cyan/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="14" y1="2" y2="2"/></svg>
      </div>
    </div>

    <div class="space-y-12">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold mb-4">Interactive Brew Assistant</h2>
        <p class="text-body max-w-lg mx-auto">
          Adjust your coffee weight and the timer will guide you through each pour.
        </p>
      </div>

      <BrewTimer client:load steps={v60Steps} totalCoffee={15} />

      <div class="grid md:grid-cols-2 gap-12 mt-24">
        <div>
          <h3 class="text-xl font-bold mb-4">Preparation</h3>
          <ul class="space-y-4">
            <li class="flex gap-4">
              <span class="text-link font-bold">01.</span>
              <p class="text-sm text-body"><strong class="text-foreground">Rinse Filter:</strong> Place the filter in the V60 and rinse with hot water to remove paper taste and preheat the brewer.</p>
            </li>
            <li class="flex gap-4">
              <span class="text-link font-bold">02.</span>
              <p class="text-sm text-body"><strong class="text-foreground">Grind Coffee:</strong> Grind 15g of coffee to a medium-fine consistency (think table salt).</p>
            </li>
            <li class="flex gap-4">
              <span class="text-link font-bold">03.</span>
              <p class="text-sm text-body"><strong class="text-foreground">Level Grounds:</strong> Add coffee to the V60 and give it a gentle shake to create a flat bed.</p>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-xl font-bold mb-4">Tips for Success</h3>
          <div class="p-6 bg-background border border-border rounded-xl space-y-4">
            <p class="text-sm text-body">
              <strong class="text-foreground">The Bloom:</strong> Don't skip this! It releases CO2 trapped in the beans, allowing water to extract flavor more effectively.
            </p>
            <p class="text-sm text-body">
              <strong class="text-foreground">Circular Pours:</strong> Pour in consistent, small circles to ensure even extraction. Avoid pouring directly against the sides.
            </p>
            <p class="text-sm text-body">
              <strong class="text-foreground">Flow Rate:</strong> If your drawdown is taking too long (>4:00), try a coarser grind next time.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
