---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/Container.astro';

const guides = await getCollection('guides');

// Helper to get color/bg based on brew method (to maintain existing style)
const getStyles = (method: string) => {
  switch (method) {
    case 'v60': return { color: 'text-cyan', bg: 'bg-cyan/10' };
    case 'chemex': return { color: 'text-violet', bg: 'bg-violet/10' };
    case 'aeropress': return { color: 'text-warning-deep', bg: 'bg-warning-soft' };
    case 'french-press': return { color: 'text-highlight-pink', bg: 'bg-highlight-pink/10' };
    case 'cold-brew': return { color: 'text-primary', bg: 'bg-primary/10' };
    case 'espresso': return { color: 'text-success', bg: 'bg-success/10' };
    default: return { color: 'text-body', bg: 'bg-background' };
  }
};
---

<Layout title="Brewing Guides" description="Master your favorite brewing methods with our interactive step-by-step guides.">
  <Container as="section" class="py-24">
    <div class="mb-16 max-w-[65ch]">
      <h1 class="mb-6 max-w-[12ch]">Brewing Guides.</h1>
      <p class="text-xl text-body max-w-[50ch] leading-relaxed">
        Select a method below to access interactive timers, specific ratios, and step-by-step instructions.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 min-w-0">
      {guides.map((guide) => {
        const styles = getStyles(guide.data.brewMethod);
        return (
          <a href={`/guides/${guide.id}`} class="group p-8 bg-card border border-border rounded-2xl shadow-sm hover:shadow-xl transition-all flex flex-col justify-between w-full min-w-0">
            <div>
              <div class={`w-12 h-12 rounded-lg ${styles.bg} ${styles.color} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform shrink-0`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="14" y1="2" y2="2"/></svg>
              </div>
              <h2 class="text-xl font-bold mb-2 truncate">{guide.data.title}</h2>
              <p class="text-sm text-body mb-6 leading-relaxed line-clamp-2 max-w-[65ch]">
                {guide.data.description}
              </p>
            </div>
            <div class="flex items-center justify-between pt-6 border-t border-border min-w-0">
              <div class="flex flex-col min-w-0">
                <span class="text-[10px] font-mono uppercase tracking-widest text-muted">Ratio</span>
                <span class="text-sm font-semibold truncate">{guide.data.ratio}</span>
              </div>
              <div class="flex flex-col text-right min-w-0">
                <span class="text-[10px] font-mono uppercase tracking-widest text-muted">Difficulty</span>
                <span class="text-sm font-semibold truncate">{guide.data.difficulty}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </Container>

  <Container as="section" class="py-24 border-t border-border">
    <div class="bg-primary rounded-2xl p-8 md:p-16 text-center text-on-primary relative overflow-hidden w-full">
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_50%_50%,#fff,transparent)] animate-pulse"></div>
      <h2 class="text-3xl md:text-5xl font-bold mb-6 max-w-[12ch] mx-auto">Missing a method?</h2>
      <p class="text-lg opacity-80 mb-10 max-w-[60ch] mx-auto">
        We're constantly adding new guides. If you have a favorite method you'd like to see, let us know or contribute to the project.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-card text-foreground font-medium rounded-pill hover:bg-background transition-colors">
        Suggest a Guide
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
    </div>
  </Container>
</Layout>
