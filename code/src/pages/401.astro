---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="401: Unauthorized" description="Please authenticate to access this coffee recipe or brewing page.">
  <Container class="py-32 text-center">
    <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-warning/10 text-warning mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.778-7.778zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
      </svg>
    </div>
    <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight text-ink">Brew credentials required.</h1>
    <p class="text-xl text-body mb-12 max-w-[50ch] mx-auto leading-relaxed">
      You need to sign in or authorize your session to view this recipe. Let's get you set up or back on track.
    </p>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4">
      <a href="/" class="px-8 py-4 bg-primary text-on-primary font-semibold rounded-2xl hover:opacity-90 transition-opacity w-full md:w-auto text-center">
        Back to Home
      </a>
      <a href="/contact" class="px-8 py-4 bg-canvas border border-hairline text-ink font-semibold rounded-2xl hover:bg-canvas-soft transition-colors w-full md:w-auto text-center">
        Contact Support
      </a>
    </div>
  </Container>
</Layout>
