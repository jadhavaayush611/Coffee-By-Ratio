---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import BrewYieldCalculator from '../components/BrewYieldCalculator';
import RelatedResources from '../components/RelatedResources.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout title="Coffee Brew Yield & Ratio Calculator" description="Calculate your coffee brew ratio based on coffee dose and final yield weight. Determine your water to coffee ratio for filter and espresso brewing.">
  <Container as="section" class="py-24">
    <div class="mb-16 max-w-[65ch]">
      <h1 class="mb-8 tracking-tight">Coffee Brew Yield Calculator</h1>
      <p class="text-xl text-body max-w-[50ch] leading-relaxed">
        Measure your results. Enter your dry coffee dose and the final weight of your beverage to find your extraction ratio.
      </p>
    </div>

    <div class="bg-canvas border border-hairline rounded-2xl shadow-2xl p-8 md:p-16 mb-24">
      <BrewYieldCalculator client:load />
    </div>

    <div class="grid md:grid-cols-2 gap-16 min-w-0">
      <div class="min-w-0">
        <h3 class="text-xl font-bold mb-4">Dose vs. Yield.</h3>
        <p class="text-sm text-body leading-relaxed mb-4 max-w-[65ch]">
          <strong>Dose</strong> is the weight of dry coffee grounds used.
        </p>
        <p class="text-sm text-body leading-relaxed max-w-[65ch]">
          <strong>Yield</strong> is the weight of the finished beverage in your cup. 
          For espresso, this is critical for consistency. For filter coffee, yield is usually ~90% of the water poured (as grounds retain about 2x their weight in water).
        </p>
      </div>
      <div class="min-w-0">
        <h3 class="text-xl font-bold mb-4">Extraction Styles.</h3>
        <ul class="space-y-4">
          <li class="flex justify-between items-center py-2 border-b border-hairline">
            <div class="min-w-0">
              <span class="text-sm font-medium block truncate">Ristretto</span>
              <span class="text-[10px] text-mute truncate">Concentrated espresso</span>
            </div>
            <span class="text-xs font-mono bg-canvas-soft px-2 py-1 rounded shrink-0">1:1 - 1:1.5</span>
          </li>
          <li class="flex justify-between items-center py-2 border-b border-hairline">
            <div class="min-w-0">
              <span class="text-sm font-medium block truncate">Normale</span>
              <span class="text-[10px] text-mute truncate">Standard espresso yield</span>
            </div>
            <span class="text-xs font-mono bg-canvas-soft px-2 py-1 rounded shrink-0">1:2 - 1:2.5</span>
          </li>
          <li class="flex justify-between items-center py-2 border-b border-hairline">
            <div class="min-w-0">
              <span class="text-sm font-medium block truncate">Lungo</span>
              <span class="text-[10px] text-mute truncate">Longer espresso pull</span>
            </div>
            <span class="text-xs font-mono bg-canvas-soft px-2 py-1 rounded shrink-0">1:3 - 1:4</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-24 min-w-0">
      <FAQ 
        title="Yield & Measurement FAQs" 
        ids={['calculate-coffee-water-ratio', '1-1-ratio-coffee-concentrate', 'weight-vs-volume-coffee', 'grams-coffee-1-liter-water']} 
      />
    </div>

    <div class="mt-24 min-w-0">
      <RelatedResources title="Brewing Guides & Tips" />
    </div>
  </Container>
</Layout>
