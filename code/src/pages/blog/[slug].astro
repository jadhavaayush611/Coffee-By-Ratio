---
import { getCollection, getEntries, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/Container.astro';
import { getReadingTime } from '../../utils/reading-time';
import BreadcrumbSchema from '../../components/schemas/BreadcrumbSchema.astro';
import BlogPostingSchema from '../../components/schemas/BlogPostingSchema.astro';
import RelatedResources from '../../components/RelatedResources.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');

const relatedPosts = post.data.relatedPosts 
  ? await getEntries(post.data.relatedPosts)
  : [];

const breadcrumbs = [
  { name: 'Home', item: 'https://coffeebyratio.com' },
  { name: 'Blog', item: 'https://coffeebyratio.com/blog' },
  { name: post.data.title, item: `https://coffeebyratio.com/blog/${post.id}` }
];
---

<Layout title={post.data.title} description={post.data.description} image={post.data.image}>
  <BreadcrumbSchema items={breadcrumbs} />
  <BlogPostingSchema 
    title={post.data.title}
    description={post.data.description}
    pubDate={post.data.pubDate}
    updatedDate={post.data.updatedDate}
    author={post.data.author}
    image={post.data.image}
    url={`https://coffeebyratio.com/blog/${post.id}`}
  />
  
  <Container as="article" class="py-24">
    <div class="max-w-[65ch] mb-12">
      <header class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <time class="text-muted text-sm" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="text-muted text-sm">•</span>
          <span class="text-muted text-sm">{readingTime}</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 tracking-tight leading-tight">
          {post.data.title}
        </h1>
        <p class="text-xl text-body leading-relaxed mb-8">
          {post.data.description}
        </p>

        <div class="flex items-center gap-3">
          {post.data.tags.map(tag => (
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold uppercase tracking-wider">
              {tag}
            </span>
          ))}
        </div>
      </header>

      {headings.length > 0 && (
        <nav class="mb-12 p-6 bg-card border border-border rounded-2xl">
          <h2 class="text-sm font-mono uppercase tracking-widest text-muted mb-4">Table of Contents</h2>
          <ul class="space-y-2">
            {headings.filter(h => h.depth <= 3).map(heading => (
              <li style={`margin-left: ${(heading.depth - 2) * 1}rem`}>
                <a href={`#${heading.slug}`} class="text-sm text-body hover:text-primary transition-colors">
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="prose prose-lg max-w-[65ch] prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary hover:prose-a:opacity-80 transition-all prose-p:text-lg prose-p:leading-8">
        <Content />
      </div>
    </div>

    <RelatedResources 
      tags={post.data.tags} 
      excludeId={post.id} 
      title="Further Reading & Tools"
    />
  </Container>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  .prose h2 {
    @apply text-3xl mt-16 mb-8 scroll-mt-24;
  }
  .prose h3 {
    @apply text-2xl mt-12 mb-6 scroll-mt-24;
  }
  .prose p {
    @apply mb-6 leading-relaxed text-body;
  }
  .prose ul, .prose ol {
    @apply mb-8 pl-6 space-y-4;
  }
  .prose li {
    @apply text-body;
  }
  .prose strong {
    @apply text-foreground font-semibold;
  }
  .prose blockquote {
    @apply border-l-4 border-primary pl-6 italic text-muted my-8;
  }
  .prose table {
    @apply w-full border-collapse mb-8;
  }
  .prose th, .prose td {
    @apply border border-hairline p-4 text-left;
  }
  .prose th {
    @apply bg-canvas-soft font-bold;
  }
</style>
